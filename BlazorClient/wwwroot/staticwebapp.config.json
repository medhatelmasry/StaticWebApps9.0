{
    "routes": [
        {
            "route": "/api/*",
            "allowedRoles": [
                "authenticated",
                "anonymous"
            ]
        },
        {
            "route": "/*",
            "serve": "/index.html",
            "statusCode": 200
        }
    ],
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/api/*",
            "*.{css,jpg,jpeg,png,gif,ico,js,svg}"
        ]
    }
}